# ============================================================
# LLM 配置（兼容所有 OpenAI 兼容接口）
# ============================================================
#
# 本项目支持灵活的 LLM 配置——你可以选择：
#   A. 不配置任何变量 → 使用本地规则推理（完全离线，零依赖）
#   B. 只填 LLM_API_KEY → 默认使用 OpenAI 官方接口
#   C. 填齐三个变量 → 使用任意 OpenAI 兼容服务商
#
# ┌───────────────────────────────────────────────────────────┐
# │  支持的服务商（非穷尽）：                                  │
# │                                                             │
# │  服务商          BASE_URL                          MODEL   │
# │  ----------     -------------------------------  -------  │
# │  OpenAI         (留空)                            gpt-4o-mini│
# │  DeepSeek       https://api.deepseek.com/v1       deepseek-chat │
# │  智谱 AI        https://open.bigmodel.cn/api/paas/v4  glm-4-flash │
# │  月之暗面 Kimi   https://api.moonshot.cn/v1        moonshot-v1-8k │
# │  通义千问        https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus │
# │  百度千帆        https://qianfan.baidubce.com/v2   (千帆模型ID) │
# │  Ollama         http://localhost:11434/v1          qwen2.5, llama3 │
# │  LM Studio      http://localhost:1234/v1           (本地模型名) │
# │  vLLM / 自部署   (你的服务地址)                       (你的模型名) │
# └───────────────────────────────────────────────────────────┘
#
# ▼▼▼ 填入你的配置 ▼▼▼

# API 密钥（Ollama 本地服务可填任意非空字符串，如 "ollama"）
LLM_API_KEY=

# 自定义 API 端点（OpenAI 官方留空即可；其他服务商必须填写）
LLM_BASE_URL=

# 模型名称（留空默认 gpt-4o-mini）
LLM_MODEL=

# ──────────────────────────────────────────────────────────
# 向后兼容（不推荐新项目使用；若设置了以上变量，会被覆盖）
# LLM_API_KEY 优先级 > OPENAI_API_KEY
# OPENAI_API_KEY=
# OPENAI_MODEL=

# ============================================================
# 知识库与反馈路径
# ============================================================

# 知识库文件路径（JSON 格式）
FAULT_KB_PATH=data/processed/fault_knowledge.json

# 用户反馈数据保存路径
FAULT_FEEDBACK_PATH=data/feedback/feedback.jsonl

# ============================================================
# 安全提示
# ============================================================
#
# 1. 请将本文件复制为 .env 后再填写真实密钥
#    cp .env.example .env   (Linux / macOS / Git Bash)
#    copy .env.example .env (Windows CMD)
#
# 2. .env 文件已在 .gitignore 中排除，不会被提交到 Git
#
# 3. 切勿将真实密钥提交到 GitHub 或任何公开仓库
#
# 4. 修改 .env 后需要重启 uvicorn 才能生效
