# ============================================================
# LLM 配置（兼容所有 OpenAI 兼容接口）
# ============================================================
#
# 本项目不绑定任何特定的 LLM 服务商。开发者可自由选择以下任何一家：
#
# 提供商            | BASE_URL                                      | 示例模型名
# ------------------|-----------------------------------------------|--------------------
# OpenAI (默认)     | 留空                                          | gpt-4o-mini, gpt-4o
# DeepSeek          | https://api.deepseek.com/v1                   | deepseek-chat, deepseek-reasoner
# 智谱 AI (GLM)     | https://open.bigmodel.cn/api/paas/v4          | glm-4-flash, glm-4
# 月之暗面 Kimi     | https://api.moonshot.cn/v1                    | moonshot-v1-8k, moonshot-v1-128k
# 通义千问          | https://dashscope.aliyuncs.com/compatible-mode/v1 | qwen-plus, qwen-turbo
# 百度千帆         | https://qianfan.baidubce.com/v2               | 对应千帆 model id
# Ollama (本地)     | http://localhost:11434/v1                     | qwen2.5, llama3, deepseek-r1
# LM Studio         | http://localhost:1234/v1                      | 本地加载的任意模型
# vLLM / 其他自部署 | 你自己的地址                                 | 对应模型名
#
# API 密钥（必须设置才能启用 LLM；Ollama 等本地服务可填任意非空字符串）
LLM_API_KEY=
# 自定义 API 端点；留空则使用 OpenAI 官方地址
LLM_BASE_URL=
# 模型名称；留空则使用 gpt-4o-mini
LLM_MODEL=

# ---- 向后兼容（不推荐新项目使用） ----
# OPENAI_API_KEY=
# OPENAI_MODEL=

# ============================================================
# 知识库路径
# ============================================================
FAULT_KB_PATH=data/processed/fault_knowledge.json
FAULT_FEEDBACK_PATH=data/feedback/feedback.jsonl
